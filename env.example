# Copy to .env in repo root for local development:
#   cp env.example .env
#
# Postgres (Docker Compose maps 5432 -> 15432)
POSTGRES_DB=secoraa
POSTGRES_USER=secoraa
POSTGRES_PASSWORD=secoraa
POSTGRES_HOST=localhost
POSTGRES_PORT=15432
DATABASE_URL=postgresql://secoraa:secoraa@127.0.0.1:15432/secoraa
# Render only — if internal dpg-* host fails DNS, set External URL from Postgres → Connect:
# DATABASE_EXTERNAL_URL=postgresql://user:pass@dpg-xxxx-a.oregon-postgres.render.com/dbname

REDIS_URL=redis://localhost:6379/0

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false

JWT_SECRET=change-me-in-local-and-prod
JWT_EXPIRES_MINUTES=240

# Frontend (optional; webpack dev defaults to http://localhost:8000 on localhost)
# REACT_APP_API_URL=http://localhost:8000
